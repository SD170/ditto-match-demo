# Copy to .env and fill in. Never commit .env.

# OpenRouter is preferred for Future Us because free/cheap models are available.
# Get a key at https://openrouter.ai/ and choose a free model if desired.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# Cerebras Inference (OpenAI-compatible): https://inference-docs.cerebras.ai/resources/openai
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# OpenAI-compatible fallback
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Browser origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Lexical RAG (BM25): max profiles passed to the matchmaker LLM after retrieval
RAG_TOP_K=12

# Set to true to test rate-limit UI without calling the LLM (free tier message)
SIMULATE_LLM_RATE_LIMIT=false

# Pexels (optional): refresh pool portraits — python scripts/fetch_pexels_pool_images.py
PEXELS_API_KEY=
