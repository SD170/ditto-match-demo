# Copy to .env and fill in. Never commit .env.

# Cerebras Inference (preferred if set): https://inference-docs.cerebras.ai/resources/openai
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# OpenAI (used when CEREBRAS_API_KEY is empty)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Browser origins for CORS (comma-separated)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Set to true to test rate-limit UI without calling the LLM (free tier message)
# SIMULATE_LLM_RATE_LIMIT=false

# Pexels (optional): refresh pool portraits — python scripts/fetch_pexels_pool_images.py
# PEXELS_API_KEY=
